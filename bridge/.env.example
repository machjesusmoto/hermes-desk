# Bridge secrets — copy to .env and fill in values
# Never commit this file.

# Hermes gateway API key (from Vault: secret/paperclip/services/hermes-gateway)
HERMES_DESK_GATEWAY__API_KEY=

# Optional: override STT/TTS endpoints
# HERMES_DESK_STT__BASE_URL=http://gx10-fd05:11436/v1
# HERMES_DESK_TTS__BASE_URL=http://gx10-39e5:11438/v1

# Optional: Tab5 auth token
# HERMES_DESK_SERVER__TOKEN=your-secret-token
