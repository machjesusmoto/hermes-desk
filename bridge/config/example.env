# Hermes Desk Bridge — Environment Configuration
# Copy to .env and fill in values

# Hermes Gateway API
HERMES_GATEWAY_URL=http://host.docker.internal:8642
HERMES_GATEWAY_KEY=your-api-server-key-here

# STT Service (Nemotron 0.6B on GB10 fd05)
STT_URL=http://10.0.2.60:11436
STT_MODEL=nemotron-stt-0.6b

# TTS Service (Google Neural2-F on GB10 39e5)
TTS_URL=http://10.0.2.61:11438
TTS_VOICE=en-US-Neural2-F
TTS_MODEL=tts-1

# Session
SESSION_ID=hermes-desk

# Bridge server
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8080

# Audio settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=pcm16

# Proactive notifications
WEBHOOK_SECRET=generate-a-strong-secret-here
