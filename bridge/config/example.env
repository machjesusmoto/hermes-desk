# Hermes Desk Bridge Configuration
# Copy to .env and customize

# Hermes API Server
HERMES_GATEWAY_URL=http://localhost:8642
HERMES_API_KEY=eos-gateway-f05e889b459121dd4af70d78d89c3900
HERMES_SESSION_ID=hermes-desk
HERMES_SYSTEM_PROMPT="You are Hermes, a voice assistant on a physical desk device. Keep responses concise and conversational. You are speaking out loud — avoid markdown, code blocks, and visual formatting."

# STT Provider
STT_PROVIDER=nemotron
STT_URL=http://10.0.2.60:11436/v1/audio/transcriptions
STT_MODEL=nvidia/nemotron-2.5-mini-0626-audio-1b

# TTS Provider
TTS_PROVIDER=google
TTS_URL=http://10.0.2.61:11438/v1/audio/speech
TTS_VOICE=galaxy
TTS_ENCODING=pcm_s16le
TTS_SAMPLE_RATE=16000

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_SAMPLE_WIDTH=2

# Server
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
ADMIN_TOKEN=hermes-desk-admin-token
ALLOWED_ORIGINS=*

# Notification
NOTIFICATION_URGENT_TIMEOUT=120
NOTIFICATION_HIGH_TIMEOUT=60
NOTIFICATION_MEDIUM_TIMEOUT=30
NOTIFICATION_LOW_TIMEOUT=10

# Quiet Hours (24h format)
QUIET_HOURS_START=23:00
QUIET_HOURS_END=07:00
QUIET_HOURS_ENABLED=false
