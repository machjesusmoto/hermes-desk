menu "Hermes Desk Configuration"

    config WIFI_SSID
        string "WiFi SSID"
        default "motowireless50"
        help
            SSID of the WiFi network the Tab5 should join.

    config WIFI_PASS
        string "WiFi Password"
        default "ownyourshitasshole"
        help
            WPA2 PSK for the WiFi network.

    config BRIDGE_HOST
        string "Bridge Host IP"
        default "10.0.2.64"
        help
            IP address of the host running the Hermes Desk bridge service.

    config BRIDGE_PORT
        int "Bridge Port"
        default 8765
        help
            WebSocket port of the bridge service.

    config BRIDGE_TOKEN
        string "Bridge Auth Token"
        default ""
        help
            Auth token for the bridge WebSocket endpoint. Leave empty if
            the bridge is running without auth (LAN-only deployment).

endmenu
